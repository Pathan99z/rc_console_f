# Copy to `.env` or `.env.local` and adjust for your machine.
# Vite only exposes variables prefixed with VITE_ to client code.

# Backend API base URL (no trailing slash).
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Request timeout (milliseconds)
VITE_API_TIMEOUT_MS=30000

# PRM: frontend base URL for invitation accept page (e.g. http://localhost:5173/prm/invite/accept)
VITE_PRM_INVITE_ACCEPT_URL=http://localhost:5173/prm/invite/accept
